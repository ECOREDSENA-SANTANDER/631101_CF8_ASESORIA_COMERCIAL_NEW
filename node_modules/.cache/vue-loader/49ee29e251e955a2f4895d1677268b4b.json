lang=\"pug\">\n  .curso-main-container.pb-3\n    BannerInterno(icono=\"far fa-question-circle\" titulo=\"Actividad didáctica\")\n    .container.tarjeta.tarjeta--blanca.p-4.p-md-5\n  \n      #Actividad                \n        <Actividad :cuestionario=\"cuestionario\"/>\n  \n  </template>\n\n<script>\nimport Actividad from 'ecored-pkg-fliz/plugin/components/actividad/Actividad.vue'\nexport default {\n  name: 'ActividadDidactica',\n  components: {\n    Actividad,\n  },\n  data: () => ({\n    cuestionario: {\n      tema: 'La postventa',\n      titulo: 'Cuestionario',\n      introduccion:\n        '<b> Objetivo:</b> Verificar la comprensión de los conceptos fundamentales del servicio postventa en el contexto comercial.',\n      barajarPreguntas: true,\n      preguntas: [\n        {\n          id: 1,\n          texto:\n            'El servicio postventa solo se aplica a productos de consumo masivo.',\n          imagen: require('@/assets/actividad/imagen1.png'),\n          barajarRespuestas: true,\n          opciones: [\n            { id: 'a', texto: 'Verdadero', esCorrecta: false },\n            { id: 'b', texto: 'Falso', esCorrecta: true },\n          ],\n          mensaje_correcto:\n            '¡Muy bien hecho! Ha captado con claridad los principios clave sobre el servicio postventa.',\n          mensaje_incorrecto:\n            'Respuesta incorrecta, revise nuevamente el contenido del componente formativo.',\n        },\n        {\n          id: 2,\n          texto:\n            'Una de las ventajas del servicio postventa es que mejora la imagen de la empresa.',\n          imagen: require('@/assets/actividad/imagen2.png'),\n          barajarRespuestas: true,\n          opciones: [\n            { id: 'a', texto: 'Verdadero', esCorrecta: true },\n            { id: 'b', texto: 'Falso', esCorrecta: false },\n          ],\n          mensaje_correcto:\n            '¡Muy bien hecho! Ha captado con claridad los principios clave sobre el servicio postventa.',\n          mensaje_incorrecto:\n            'Respuesta incorrecta, revise nuevamente el contenido del componente formativo.',\n        },\n        {\n          id: 3,\n          texto:\n            'El servicio de atención al cliente y el servicio postventa son completamente independientes y no tienen relación.',\n          imagen: require('@/assets/actividad/imagen3.png'),\n          barajarRespuestas: true,\n          opciones: [\n            { id: 'a', texto: 'Verdadero', esCorrecta: false },\n            { id: 'b', texto: 'Falso', esCorrecta: true },\n          ],\n          mensaje_correcto:\n            '¡Muy bien hecho! Ha captado con claridad los principios clave sobre el servicio postventa.',\n          mensaje_incorrecto:\n            'Respuesta incorrecta, revise nuevamente el contenido del componente formativo.',\n        },\n        {\n          id: 4,\n          texto:\n            'El proceso de calidad del servicio postventa incluye planificación, implementación, control y mejora.',\n          imagen: require('@/assets/actividad/imagen4.png'),\n          barajarRespuestas: true,\n          opciones: [\n            { id: 'a', texto: 'Verdadero', esCorrecta: true },\n            { id: 'b', texto: 'Falso', esCorrecta: false },\n          ],\n          mensaje_correcto:\n            '¡Muy bien hecho! Ha captado con claridad los principios clave sobre el servicio postventa.',\n          mensaje_incorrecto:\n            'Respuesta incorrecta, revise nuevamente el contenido del componente formativo.',\n        },\n        {\n          id: 5,\n          texto:\n            'Los servicios postventa incluyen únicamente garantías y reparaciones técnicas.',\n          imagen: require('@/assets/actividad/imagen1.png'),\n          barajarRespuestas: true,\n          opciones: [\n            { id: 'a', texto: 'Verdadero', esCorrecta: false },\n            { id: 'b', texto: 'Falso', esCorrecta: true },\n          ],\n          mensaje_correcto:\n            '¡Muy bien hecho! Ha captado con claridad los principios clave sobre el servicio postventa.',\n          mensaje_incorrecto:\n            'Respuesta incorrecta, revise nuevamente el contenido del componente formativo.',\n        },\n        {\n          id: 6,\n          texto:\n            'La fidelización del cliente es uno de los objetivos clave del servicio postventa.',\n          imagen: require('@/assets/actividad/imagen2.png'),\n          barajarRespuestas: true,\n          opciones: [\n            { id: 'a', texto: 'Verdadero', esCorrecta: true },\n            { id: 'b', texto: 'Falso', esCorrecta: false },\n          ],\n          mensaje_correcto:\n            '¡Muy bien hecho! Ha captado con claridad los principios clave sobre el servicio postventa.',\n          mensaje_incorrecto:\n            'Respuesta incorrecta, revise nuevamente el contenido del componente formativo.',\n        },\n        {\n          id: 7,\n          texto:\n            'Las quejas y reclamaciones no deben considerarse dentro de la estrategia de postventa.',\n          imagen: require('@/assets/actividad/imagen3.png'),\n          barajarRespuestas: true,\n          opciones: [\n            { id: 'a', texto: 'Verdadero', esCorrecta: false },\n            { id: 'b', texto: 'Falso', esCorrecta: true },\n          ],\n          mensaje_correcto:\n            '¡Muy bien hecho! Ha captado con claridad los principios clave sobre el servicio postventa.',\n          mensaje_incorrecto:\n            'Respuesta incorrecta, revise nuevamente el contenido del componente formativo.',\n        },\n        {\n          id: 8,\n          texto:\n            'Los indicadores de servicio postventa permiten medir la calidad del servicio y detectar áreas de mejora.',\n          imagen: require('@/assets/actividad/imagen4.png'),\n          barajarRespuestas: true,\n          opciones: [\n            { id: 'a', texto: 'Verdadero', esCorrecta: true },\n            { id: 'b', texto: 'Falso', esCorrecta: false },\n          ],\n          mensaje_correcto:\n            '¡Muy bien hecho! Ha captado con claridad los principios clave sobre el servicio postventa.',\n          mensaje_incorrecto:\n            'Respuesta incorrecta, revise nuevamente el contenido del componente formativo.',\n        },\n        {\n          id: 9,\n          texto:\n            'Un servicio postventa eficiente puede contribuir al incremento de las ventas de una empresa.',\n          imagen: require('@/assets/actividad/imagen1.png'),\n          barajarRespuestas: true,\n          opciones: [\n            { id: 'a', texto: 'Verdadero', esCorrecta: true },\n            { id: 'b', texto: 'Falso', esCorrecta: false },\n          ],\n          mensaje_correcto:\n            '¡Muy bien hecho! Ha captado con claridad los principios clave sobre el servicio postventa.',\n          mensaje_incorrecto:\n            'Respuesta incorrecta, revise nuevamente el contenido del componente formativo.',\n        },\n        {\n          id: 10,\n          texto:\n            'El servicio postventa solo es responsabilidad del departamento de ventas.',\n          imagen: require('@/assets/actividad/imagen2.png'),\n          barajarRespuestas: true,\n          opciones: [\n            { id: 'a', texto: 'Verdadero', esCorrecta: false },\n            { id: 'b', texto: 'Falso', esCorrecta: true },\n          ],\n          mensaje_correcto:\n            '¡Muy bien hecho! Ha captado con claridad los principios clave sobre el servicio postventa.',\n          mensaje_incorrecto:\n            'Respuesta incorrecta, revise nuevamente el contenido del componente formativo.',\n        },\n      ],\n      mensaje_final_aprobado:\n        '¡Felicidades! Correctas sus respuestas, significa que ha comprendido la importancia del servicio postventa y su impacto en la fidelización de clientes. ¡Siga aplicando estos conocimientos en la práctica!',\n      mensaje_final_reprobado:\n        'No ha superado la actividad. Le recomendamos volver a revisar el componente formativo e intentar nuevamente la actividad didáctica.',\n    },\n  }),\n}\n</script>\n"]}]}